generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  firstName      String?
  lastName       String?
  name           String?
  email          String          @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           UserRole        @default(USER)
  accounts       Account[]
  sessions       Session[]
  authenticators Authenticator[]

  bio      String? @db.Text
  headline String?
  location String?
  timezone String? @default("Africa/Lagos")
  socials  Json?
  publicProfileSlug   String?              @unique
  publicProfileStatus PublicProfileStatus  @default(DRAFT)
  websiteUrl          String?
  portfolioUrl        String?
  linkedinUrl         String?
  twitterUrl          String?
  instagramUrl        String?
  youtubeUrl          String?
  githubUrl           String?
  behanceUrl          String?
  dribbbleUrl         String?
  telegramUrl         String?
  expertise           Json?
  learningFocus       String?
  yearsExperience Int?
  instructorProfileEnabled Boolean @default(false)
  instructorVerificationStatus InstructorVerificationStatus @default(NOT_STARTED)
  instructorVerifiedAt DateTime?
  instructorFeatured Boolean @default(false)
  instructorFeaturedOrder Int?
  mentorshipEligible Boolean @default(false)
  mentorshipEnabled Boolean @default(false)
  mentorshipApprovedAt DateTime?
  mentorshipPrice Decimal? @db.Decimal(10, 2)
  mentorshipCurrency String @default("NGN")
  mentorshipFree Boolean @default(true)
  mentorshipBio String? @db.Text
  mentorshipTopics Json?
  mentorshipInstructions String? @db.Text

  // Admin permission scopes — only relevant when role == ADMIN
  // SUPER_ADMIN implicitly has all permissions
  canManageUsers         Boolean @default(false)
  canManageCourses       Boolean @default(false)
  canReviewCourses       Boolean @default(false)
  canPublishCourses      Boolean @default(false)
  canManageLearners      Boolean @default(false)
  canManageInstructors   Boolean @default(false)
  canVerifyInstructors   Boolean @default(false)
  canManageInvites       Boolean @default(false)
  canManageAnnouncements Boolean @default(false)
  canManageBilling       Boolean @default(false)
  canManageMarketing     Boolean @default(false)
  canManagePermissions   Boolean @default(false)
  canViewAuditLogs       Boolean @default(false)
  canManageSettings      Boolean @default(false)
  canViewAnalytics       Boolean @default(false)

  marketingConsent Boolean @default(false)

  // Course relations
  taughtCourses     Course[]             @relation("InstructorCourses")
  enrollments       Enrollment[]
  purchaseOrders    PurchaseOrder[]      @relation("StudentOrders")
  payments          Payment[]
  instructorEarnings InstructorEarning[] @relation("InstructorEarnings")
  payoutRequests    PayoutRequest[]      @relation("InstructorPayoutRequests")
  reviewedPayoutRequests PayoutRequest[] @relation("PayoutRequestReviewer")
  payouts           Payout[]             @relation("InstructorPayouts")
  refundsRequested  Refund[]             @relation("RefundRequester")
  refundsReviewed   Refund[]             @relation("RefundReviewer")
  invoices          Invoice[]
  subscriptions     UserSubscription[]
  progress          LessonProgress[]
  lessonNotes       LessonNote[]
  watchSegments     LessonWatchSegment[]
  quizAttempts      QuizAttempt[]
  courseInstructors CourseInstructor[]
  createdScheduleEvents ScheduleEvent[] @relation("ScheduleEventCreator")
  startedScheduleEvents ScheduleEvent[] @relation("ScheduleEventStarter")
  endedScheduleEvents ScheduleEvent[] @relation("ScheduleEventEnder")
  scheduleAttendances ScheduleEventAttendee[] @relation("ScheduleEventAttendees")
  mentorAvailabilities MentorAvailability[] @relation("MentorAvailabilities")
  mentorBookings MentorBooking[] @relation("MentorBookings")
  mentorshipBookings MentorBooking[] @relation("MentorshipBookings")
  mentorshipApplications MentorshipApplication[] @relation("MentorshipApplications")
  reviewedMentorshipApplications MentorshipApplication[] @relation("MentorshipApplicationReviewer")
  calendarConnections CalendarConnection[]
  notifications     Notification[]
  emailOutbox        EmailOutbox[]
  auditLogs         AuditLog[]           @relation("AuditActor")
  courseReviews     CourseReview[]
  courseFeedback    CourseFeedbackItem[] @relation("FeedbackAuthor")
  dailyActivities   DailyActivity[]
  ratings           CourseRating[]
  examAttempts      ExamAttempt[]
  pricingProposals  CoursePricingProposal[] @relation("PricingProposalSubmitter")
  reviewedPricingProposals CoursePricingProposal[] @relation("PricingProposalReviewer")
  // Streak & Gamification relations
  currentStreak     Int                 @default(0)
  longestStreak     Int                 @default(0)
  achievements      UserAchievement[]
  questProgress     UserQuestProgress[]
  leaderboardRecord LeaderboardCache?

  // Payout Configuration
  payoutSetup      Boolean @default(false)
  payoutMethod     String?
  payoutDetails    Json?

  // Security (2FA)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([publicProfileStatus])
  @@index([instructorProfileEnabled, instructorVerificationStatus])
  @@index([instructorFeatured, instructorFeaturedOrder])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  INSTRUCTOR
  USER
}

enum InstructorVerificationStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  REJECTED
}

enum PublicProfileStatus {
  DRAFT
  PUBLIC
  HIDDEN
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique @default(uuid())
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model InviteToken {
  id        String    @id @default(cuid())
  token     String    @unique @default(cuid())
  email     String?
  role      UserRole
  createdBy String
  usedBy    String?
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())
}

// ─── Course System ────────────────────────────────────────────────────────────

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]

  createdAt DateTime @default(now())
}

model Course {
  id           String       @id @default(cuid())
  title        String
  slug         String       @unique
  description  String       @db.Text
  shortDesc    String?
  thumbnail    String?
  promoVideo   String?
  difficulty   Difficulty   @default(BEGINNER)
  courseType   CourseType   @default(FULL_COURSE)
  status       CourseStatus @default(DRAFT)
  previewCount Int          @default(1)
  price        Decimal?     @db.Decimal(10, 2)
  baseCurrency String       @default("NGN")
  duration     Int? // total minutes, computed on publish
  requirements Json? // String[] — what students need before starting
  includes     Json? // String[] — what the course provides (video hours, cert, etc.)

  certificateEnabled Boolean   @default(false)
  examGated          Boolean   @default(false)
  metaTitle          String?
  metaDescription    String?

  finalExamId  String?       @unique
  finalExam    Exam?         @relation("CourseFinalExam", fields: [finalExamId], references: [id])

  categoryId   String?
  category     Category? @relation(fields: [categoryId], references: [id])
  instructorId String
  instructor   User      @relation("InstructorCourses", fields: [instructorId], references: [id])

  featuredOrder Int? // 1–8 = appears on landing page in this position

  modules       Module[]
  enrollments   Enrollment[]
  instructors   CourseInstructor[]
  courseInvites CourseInvite[]
  reviews       CourseReview[]
  revisions     CourseRevision[]
  feedbackItems CourseFeedbackItem[]
  ratings       CourseRating[]
  pricingProposals CoursePricingProposal[]
  purchaseOrders PurchaseOrder[]
  instructorEarnings InstructorEarning[]
  scheduleEvents ScheduleEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Module {
  id          String   @id @default(cuid())
  title       String
  position    Int
  isPublished Boolean  @default(false)
  isDefault   Boolean  @default(false)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model Lesson {
  id          String      @id @default(cuid())
  title       String
  overview    String?     @db.Text
  position    Int
  videoUrl    String? // Legacy YouTube URL
  contentType ContentType @default(VIDEO)
  bodyContent String?     @db.Text
  duration    Int? // minutes
  isPreview   Boolean     @default(false)
  isPublished Boolean     @default(false)
  transcript  String?     @db.Text
  moduleId    String
  module      Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  // Mux video hosting
  muxUploadId   String?        @unique
  muxAssetId    String?        @unique
  muxPlaybackId String?        @unique
  muxStatus     MuxVideoStatus @default(NONE)

  resources LessonResource[]
  progress  LessonProgress[]
  notes     LessonNote[]
  watchSegments LessonWatchSegment[]
  quiz      Quiz?
  scheduleEvents ScheduleEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
}

model LessonResource {
  id       String       @id @default(cuid())
  title    String
  url      String
  type     ResourceType @default(LINK)
  lessonId String
  lesson   Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model Quiz {
  id              String   @id @default(cuid())
  lessonId        String   @unique
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  mode            QuizMode @default(PRACTICE)
  instructions    String?  @db.Text
  passingScore    Int?
  maxAttempts     Int?
  showAnswers     Boolean  @default(true)
  gateUntilPassed Boolean  @default(false)
  shuffleQuestions Boolean @default(false)
  timeLimitMinutes Int?

  questions QuizQuestion[]
  attempts  QuizAttempt[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
}

model QuizQuestion {
  id          String           @id @default(cuid())
  quizId      String
  quiz        Quiz             @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type        QuizQuestionType @default(SINGLE_CHOICE)
  prompt      String           @db.Text
  explanation String?          @db.Text
  points      Int              @default(1)
  position    Int
  required    Boolean          @default(true)

  options QuizOption[]
  answers QuizAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([quizId])
}

model QuizOption {
  id         String       @id @default(cuid())
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String       @db.Text
  isCorrect  Boolean      @default(false)
  position   Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([questionId])
}

model QuizAttempt {
  id            String            @id @default(cuid())
  quizId        String
  quiz          Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  attemptNumber Int
  status        QuizAttemptStatus @default(IN_PROGRESS)
  score         Float             @default(0)
  maxScore      Float             @default(0)
  percentage    Float             @default(0)
  passed        Boolean           @default(false)
  startedAt     DateTime          @default(now())
  submittedAt   DateTime?

  answers QuizAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([quizId, userId, attemptNumber])
  @@index([quizId])
  @@index([userId])
  @@index([userId, status])
}

model QuizAnswer {
  id                     String       @id @default(cuid())
  attemptId              String
  attempt                QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId             String
  question               QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOptionIds      Json?
  isCorrect              Boolean      @default(false)
  pointsAwarded          Float        @default(0)
  questionPromptSnapshot String       @db.Text
  optionSnapshots        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
}

model Enrollment {
  id       String           @id @default(cuid())
  userId   String
  courseId String
  status   EnrollmentStatus @default(ACTIVE)
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  course   Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)

  enrolledAt  DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String
  lastSeekTime    Float    @default(0.0)
  percentComplete Int      @default(0)
  completedAt     DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson          Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Difficulty {
  ALL_LEVELS
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum CourseType {
  SHORT_COURSE
  FULL_COURSE
  PROFESSIONAL_CERTIFICATE
}

enum CourseStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum ContentType {
  VIDEO
  ARTICLE
  QUIZ
}

enum ResourceType {
  PDF
  LINK
  FILE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

// ─── Billing & Ledger ─────────────────────────────────────────────────────────

model PurchaseOrder {
  id                String              @id @default(cuid())
  userId            String
  courseId          String?
  mentorBookingId   String?             @unique
  type              OrderType           @default(COURSE)
  status            OrderStatus         @default(PENDING)
  amount            Decimal             @db.Decimal(12, 2)
  currency          String              @default("NGN")
  provider          PaymentProvider?
  providerReference String?             @unique
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  user     User    @relation("StudentOrders", fields: [userId], references: [id], onDelete: Cascade)
  course   Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)
  mentorBooking MentorBooking? @relation(fields: [mentorBookingId], references: [id], onDelete: SetNull)
  payments Payment[]
  earnings InstructorEarning[]
  refunds  Refund[]
  invoice  Invoice?

  @@index([userId])
  @@index([courseId])
  @@index([mentorBookingId])
  @@index([status])
  @@index([createdAt])
}

model Payment {
  id                String          @id @default(cuid())
  orderId           String
  userId            String
  provider          PaymentProvider
  channel           String?
  status            PaymentStatus   @default(PENDING)
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("NGN")
  providerReference String?         @unique
  rawPayload        Json?
  paidAt            DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  order    PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  earnings InstructorEarning[]
  refunds  Refund[]

  @@index([orderId])
  @@index([userId])
  @@index([provider, status])
  @@index([createdAt])
}

model InstructorEarning {
  id               String        @id @default(cuid())
  instructorId     String
  courseId         String?
  orderId          String?
  paymentId        String?
  grossAmount      Decimal       @db.Decimal(12, 2)
  platformFee      Decimal       @db.Decimal(12, 2)
  instructorAmount Decimal       @db.Decimal(12, 2)
  currency         String        @default("NGN")
  sharePercent     Decimal       @default(80.00) @db.Decimal(5, 2)
  status           EarningStatus @default(PENDING)
  payoutRequestId  String?
  holdUntil        DateTime?
  availableAt      DateTime?
  paidAt           DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  instructor User           @relation("InstructorEarnings", fields: [instructorId], references: [id], onDelete: Cascade)
  course     Course?        @relation(fields: [courseId], references: [id], onDelete: SetNull)
  order      PurchaseOrder? @relation(fields: [orderId], references: [id], onDelete: SetNull)
  payment    Payment?       @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  payoutRequest PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)

  @@index([instructorId])
  @@index([courseId])
  @@index([status])
  @@index([payoutRequestId])
  @@index([createdAt])
}

model PayoutRequest {
  id            String              @id @default(cuid())
  instructorId  String
  amount        Decimal             @db.Decimal(12, 2)
  currency      String              @default("NGN")
  status        PayoutRequestStatus @default(REQUESTED)
  payoutMethod  String?
  payoutDetails Json?
  adminNote     String?             @db.Text
  requestedAt   DateTime            @default(now())
  reviewedById  String?
  reviewedAt    DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  instructor User    @relation("InstructorPayoutRequests", fields: [instructorId], references: [id], onDelete: Cascade)
  reviewedBy User?   @relation("PayoutRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  payouts    Payout[]
  earnings   InstructorEarning[]

  @@index([instructorId])
  @@index([status])
  @@index([requestedAt])
}

model Payout {
  id                String       @id @default(cuid())
  payoutRequestId   String?
  instructorId      String
  amount            Decimal      @db.Decimal(12, 2)
  currency          String       @default("NGN")
  provider          PaymentProvider?
  status            PayoutStatus @default(PENDING)
  providerReference String?
  metadata          Json?
  paidAt            DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  payoutRequest PayoutRequest? @relation(fields: [payoutRequestId], references: [id], onDelete: SetNull)
  instructor    User           @relation("InstructorPayouts", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([payoutRequestId])
  @@index([instructorId])
  @@index([status])
  @@index([createdAt])
}

model WebhookEvent {
  id          String          @id @default(cuid())
  provider    PaymentProvider
  eventId     String
  eventType   String
  rawPayload  Json?
  processedAt DateTime?
  createdAt   DateTime        @default(now())

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([createdAt])
}

model Refund {
  id            String       @id @default(cuid())
  orderId       String
  paymentId     String?
  requestedById String?
  reviewedById  String?
  amount        Decimal      @db.Decimal(12, 2)
  currency      String       @default("NGN")
  status        RefundStatus @default(REQUESTED)
  reason        String?      @db.Text
  providerReference String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  reviewedAt    DateTime?
  completedAt   DateTime?

  order       PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment     Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  requestedBy User?         @relation("RefundRequester", fields: [requestedById], references: [id], onDelete: SetNull)
  reviewedBy  User?         @relation("RefundReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([paymentId])
  @@index([status])
  @@index([createdAt])
}

model Invoice {
  id        String        @id @default(cuid())
  orderId   String        @unique
  userId    String
  number    String        @unique
  amount    Decimal       @db.Decimal(12, 2)
  currency  String        @default("NGN")
  status    InvoiceStatus @default(ISSUED)
  issuedAt  DateTime      @default(now())
  metadata  Json?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([issuedAt])
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?  @db.Text
  amount      Decimal  @db.Decimal(12, 2)
  currency    String   @default("NGN")
  interval    String   @default("MONTH")
  active      Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id                  String             @id @default(cuid())
  userId              String
  planId              String
  status              SubscriptionStatus @default(ACTIVE)
  provider            PaymentProvider?
  providerReference   String?
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([planId])
  @@index([status])
}

enum OrderType {
  COURSE
  MENTORSHIP
  SUBSCRIPTION
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  MANUAL
  PAYSTACK
  STRIPE
  CRYPTO
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

enum EarningStatus {
  PENDING
  AVAILABLE
  REQUESTED
  PAID
  REVERSED
}

enum PayoutRequestStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  SUCCEEDED
  FAILED
}

enum InvoiceStatus {
  ISSUED
  PAID
  VOID
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum QuizQuestionType {
  SINGLE_CHOICE
  MULTIPLE_SELECT
  TRUE_FALSE
}

enum QuizAttemptStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

enum QuizMode {
  PRACTICE
  GRADED
}

model LessonNote {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  body      String   @db.Text
  timestamp Float?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, lessonId])
  @@index([lessonId])
}

model LessonWatchSegment {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  segmentIndex   Int
  secondsWatched Int      @default(0)
  lastSeenAt     DateTime @updatedAt
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, userId, segmentIndex])
  @@index([lessonId, segmentIndex])
  @@index([userId])
}

model CoursePricingProposal {
  id                   String                @id @default(cuid())
  courseId             String
  proposedPrice        Decimal?              @db.Decimal(10, 2)
  currentPriceSnapshot Decimal?              @db.Decimal(10, 2)
  currency             String                @default("NGN")
  status               PricingProposalStatus @default(PENDING)
  submittedById        String
  reviewedById         String?
  adminNote            String?               @db.Text
  reviewedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  course      Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submittedBy User   @relation("PricingProposalSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?  @relation("PricingProposalReviewer", fields: [reviewedById], references: [id])

  @@index([courseId])
  @@index([status])
  @@index([submittedById])
}

enum PricingProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MuxVideoStatus {
  NONE
  UPLOADING
  PROCESSING
  READY
  ERROR
}

enum CourseInstructorRole {
  OWNER
  CO_INSTRUCTOR
  TEACHING_ASSISTANT
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id             String              @id @default(cuid())
  userId         String
  type           NotificationType
  title          String
  body           String?
  data           Json? // context payload: { courseId, token, reviewId, … }
  seenAt         DateTime?
  readAt         DateTime?
  actionRequired Boolean             @default(false)
  actionStatus   NotificationActionStatus?
  actionLabel    String?
  actionUrl      String?
  expiresAt      DateTime?
  emailSentAt    DateTime?
  emailFailedAt  DateTime?
  emailError     String?
  createdAt      DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, seenAt])
  @@index([userId, actionRequired, actionStatus])
}

model EmailOutbox {
  id             String            @id @default(cuid())
  recipientUserId String?
  recipientEmail String
  recipientName  String?
  type           EmailOutboxType
  subject        String
  payload        Json
  status         EmailOutboxStatus @default(PENDING)
  attempts       Int               @default(0)
  maxAttempts    Int               @default(3)
  nextAttemptAt  DateTime          @default(now())
  sentAt         DateTime?
  failedAt       DateTime?
  lastError      String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  recipientUser User? @relation(fields: [recipientUserId], references: [id], onDelete: SetNull)

  @@index([status, nextAttemptAt])
  @@index([recipientUserId])
  @@index([type])
  @@index([createdAt])
}

enum NotificationType {
  COURSE_INVITE
  COURSE_FEEDBACK
  COURSE_FEEDBACK_RESOLVED
  COURSE_PUBLISHED
  COURSE_REJECTED
  COURSE_CHANGES_REQUESTED
  NEW_ENROLLMENT
  SYSTEM
}

enum EmailOutboxType {
  LIVE_SESSION_REMINDER
  LIVE_SESSION_UPDATE
}

enum EmailOutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD
}

enum NotificationActionStatus {
  PENDING
  COMPLETED
  DISMISSED
  EXPIRED
}

// ─── Announcements ────────────────────────────────────────────────────────────

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String               @db.Text
  audience    AnnouncementAudience @default(ALL)
  status      AnnouncementStatus   @default(DRAFT)
  priority    Int                  @default(0)
  linkUrl     String?
  publishedAt DateTime? // null = draft; future date = scheduled
  expiresAt   DateTime?
  authorId    String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([status])
  @@index([audience, publishedAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorName  String?
  actorEmail String?
  action     String
  entityType String
  entityId   String?
  entityName String?
  metadata   Json?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}

enum AnnouncementAudience {
  ALL
  INSTRUCTORS
  STUDENTS
  ADMINS
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Scheduling ───────────────────────────────────────────────────────────────

model ScheduleEvent {
  id           String                @id @default(cuid())
  type         ScheduleEventType
  status       ScheduleEventStatus   @default(SCHEDULED)
  audience     ScheduleEventAudience @default(COURSE_ENROLLEES)
  title        String
  description  String?               @db.Text
  startsAt     DateTime              @db.Timestamptz(3)
  endsAt       DateTime?             @db.Timestamptz(3)
  timezone     String                @default("Africa/Lagos")
  meetingUrl   String?
  meetingProvider ScheduleMeetingProvider @default(MANUAL)
  meetingStatus   ScheduleMeetingStatus   @default(NONE)
  recordingUrl String?
  metadata     Json?
  createdById  String?
  startedAt    DateTime?             @db.Timestamptz(3)
  startedById  String?
  endedAt      DateTime?             @db.Timestamptz(3)
  endedById    String?
  courseId     String?
  lessonId     String?
  examId       String?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  createdBy User?   @relation("ScheduleEventCreator", fields: [createdById], references: [id], onDelete: SetNull)
  startedBy User?   @relation("ScheduleEventStarter", fields: [startedById], references: [id], onDelete: SetNull)
  endedBy   User?   @relation("ScheduleEventEnder", fields: [endedById], references: [id], onDelete: SetNull)
  course    Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson    Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  exam      Exam?   @relation(fields: [examId], references: [id], onDelete: SetNull)
  attendees ScheduleEventAttendee[]
  externalCalendar ScheduleEventExternalCalendar?
  reminderDeliveries ScheduleReminderDelivery[]

  @@index([type])
  @@index([status])
  @@index([audience])
  @@index([startsAt])
  @@index([courseId, startsAt])
  @@index([createdById])
  @@index([startedById])
  @@index([endedById])
}

model CalendarConnection {
  id                   String                   @id @default(cuid())
  userId               String
  provider             CalendarProvider
  providerAccountEmail String?
  calendarId           String                   @default("primary")
  accessTokenEncrypted String                   @db.Text
  refreshTokenEncrypted String?                 @db.Text
  tokenExpiresAt       DateTime?
  scopes               String?                  @db.Text
  status               CalendarConnectionStatus @default(CONNECTED)
  lastSyncedAt         DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalCalendarEvents ScheduleEventExternalCalendar[]

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider, status])
}

model ScheduleEventExternalCalendar {
  id                   String                   @id @default(cuid())
  scheduleEventId      String                   @unique
  calendarConnectionId String
  provider             CalendarProvider
  externalEventId      String?
  externalHtmlLink     String?
  externalICalUid      String?
  conferenceRequestId  String?
  conferenceStatus     CalendarConferenceStatus @default(PENDING)
  meetingUrl           String?
  conferenceId         String?
  syncError            String?                  @db.Text
  lastSyncedAt         DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  scheduleEvent      ScheduleEvent      @relation(fields: [scheduleEventId], references: [id], onDelete: Cascade)
  calendarConnection CalendarConnection @relation(fields: [calendarConnectionId], references: [id], onDelete: Cascade)

  @@index([calendarConnectionId])
  @@index([provider])
  @@index([conferenceStatus])
}

model MentorAvailability {
  id              String                       @id @default(cuid())
  mentorId        String
  type            MentorAvailabilityType       @default(WEEKLY)
  weekday         Int?
  date            String?
  startTime       String
  endTime         String
  timezone        String                       @default("Africa/Lagos")
  sessionDuration Int                          @default(45)
  bufferMinutes   Int                          @default(10)
  maxBookings     Int                          @default(1)
  recurrence      MentorAvailabilityRecurrence @default(WEEKLY)
  status          MentorAvailabilityStatus     @default(ACTIVE)
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  mentor User @relation("MentorAvailabilities", fields: [mentorId], references: [id], onDelete: Cascade)
  bookings MentorBooking[]

  @@index([mentorId])
  @@index([status])
  @@index([type, weekday])
  @@index([date])
}

model MentorBooking {
  id              String              @id @default(cuid())
  mentorId        String
  studentId       String?
  availabilityId  String?
  status          MentorBookingStatus @default(PENDING)
  startsAt        DateTime            @db.Timestamptz(3)
  endsAt          DateTime            @db.Timestamptz(3)
  timezone        String              @default("Africa/Lagos")
  topic           String?
  studentNote     String?             @db.Text
  mentorNote      String?             @db.Text
  rescheduleRequestedById String?
  rescheduleRequestedAt DateTime?      @db.Timestamptz(3)
  proposedStartsAt DateTime?           @db.Timestamptz(3)
  proposedEndsAt DateTime?             @db.Timestamptz(3)
  proposedTimezone String?
  rescheduleNote String?               @db.Text
  rescheduleRespondedAt DateTime?      @db.Timestamptz(3)
  rescheduleResponseNote String?       @db.Text
  price           Decimal?            @db.Decimal(10, 2)
  currency        String              @default("NGN")
  meetingUrl      String?
  scheduleEventId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  mentor User @relation("MentorBookings", fields: [mentorId], references: [id], onDelete: Cascade)
  student User? @relation("MentorshipBookings", fields: [studentId], references: [id], onDelete: SetNull)
  availability MentorAvailability? @relation(fields: [availabilityId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?

  @@unique([availabilityId, startsAt])
  @@index([mentorId])
  @@index([studentId])
  @@index([status])
  @@index([startsAt])
}

model MentorshipApplication {
  id                 String                      @id @default(cuid())
  instructorId       String
  status             MentorshipApplicationStatus @default(PENDING)
  pitch              String?                     @db.Text
  audience           String?                     @db.Text
  sessionTypes       Json?
  topics             Json?
  mentorshipFree     Boolean                     @default(true)
  proposedPrice      Decimal?                    @db.Decimal(10, 2)
  proposedCurrency   String                      @default("NGN")
  instructions       String?                     @db.Text
  submittedAt        DateTime                    @default(now())
  reviewedAt         DateTime?
  reviewedById       String?
  reviewNote         String?                     @db.Text
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  instructor User  @relation("MentorshipApplications", fields: [instructorId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("MentorshipApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([instructorId])
  @@index([status])
  @@index([submittedAt])
}

model ScheduleEventAttendee {
  id              String                   @id @default(cuid())
  eventId         String
  userId          String
  status          ScheduleAttendanceStatus @default(INVITED)
  reminderEnabled Boolean                  @default(false)
  lastNotifiedAt  DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  event ScheduleEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User          @relation("ScheduleEventAttendees", fields: [userId], references: [id], onDelete: Cascade)
  reminderDeliveries ScheduleReminderDelivery[]

  @@unique([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@index([status])
}

model ScheduleReminderDelivery {
  id          String                         @id @default(cuid())
  eventId     String
  attendeeId  String
  userId      String
  kind        ScheduleReminderKind
  status      ScheduleReminderDeliveryStatus @default(PENDING)
  scheduledFor DateTime                      @db.Timestamptz(3)
  deliveredAt DateTime?                     @db.Timestamptz(3)
  cancelledAt DateTime?                     @db.Timestamptz(3)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt

  event    ScheduleEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee ScheduleEventAttendee @relation(fields: [attendeeId], references: [id], onDelete: Cascade)

  @@unique([attendeeId, kind])
  @@index([eventId])
  @@index([userId])
  @@index([status, scheduledFor])
}

enum ScheduleEventType {
  LIVE_SESSION
  MENTORSHIP
  EXAM
  DEADLINE
  PLATFORM_EVENT
}

enum ScheduleEventStatus {
  DRAFT
  SCHEDULED
  LIVE
  COMPLETED
  CANCELLED
}

enum ScheduleEventAudience {
  ALL_STUDENTS
  COURSE_ENROLLEES
  SELECTED_USERS
  INSTRUCTORS
  ADMINS
}

enum ScheduleAttendanceStatus {
  INVITED
  REGISTERED
  ATTENDED
  MISSED
  CANCELLED
}

enum ScheduleReminderKind {
  BEFORE_45_MINUTES
  JOIN_WINDOW
}

enum ScheduleReminderDeliveryStatus {
  PENDING
  DELIVERED
  CANCELLED
}

enum CalendarProvider {
  GOOGLE
  MICROSOFT
  ZOOM
}

enum CalendarConnectionStatus {
  CONNECTED
  EXPIRED
  REVOKED
  ERROR
}

enum ScheduleMeetingProvider {
  MANUAL
  GOOGLE_MEET
  MICROSOFT_TEAMS
  ZOOM
}

enum ScheduleMeetingStatus {
  NONE
  PENDING
  READY
  FAILED
}

enum CalendarConferenceStatus {
  PENDING
  SUCCESS
  FAILED
}

enum MentorAvailabilityType {
  WEEKLY
  DATE
}

enum MentorAvailabilityRecurrence {
  WEEKLY
  ONCE
}

enum MentorAvailabilityStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum MentorBookingStatus {
