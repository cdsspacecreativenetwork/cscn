// ─── Course Reviews ───────────────────────────────────────────────────────────

model CourseReview {
  id          String       @id @default(cuid())
  courseId    String
  reviewerId  String
  status      ReviewStatus
  comment     String?      @db.Text
  revisionId  String?
  addressedAt DateTime?
  addressedBy String?
  createdAt   DateTime     @default(now())

  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviewer User   @relation(fields: [reviewerId], references: [id])
  revision CourseRevision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)

  @@index([courseId])
  @@index([revisionId])
}

enum ReviewStatus {
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

model CourseRevision {
  id             String               @id @default(cuid())
  courseId       String
  version        Int
  status         CourseRevisionStatus @default(DRAFT)
  liveSnapshot   Json?
  draftSnapshot  Json
  changeSummary  Json?
  submittedById  String?
  submittedAt    DateTime?
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?              @db.Text
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  course  Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  reviews CourseReview[]

  @@unique([courseId, version])
  @@index([courseId, status])
  @@index([submittedAt])
}

enum CourseRevisionStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED
  REJECTED
  SUPERSEDED
}

// ─── Co-instructor System ─────────────────────────────────────────────────────

model CourseInstructor {
  id        String               @id @default(cuid())
  courseId  String
  userId    String
  role      CourseInstructorRole @default(CO_INSTRUCTOR)
  createdAt DateTime             @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
}

// Invite sent by an OWNER to bring in a co-instructor or TA
model CourseInvite {
  id        String               @id @default(cuid())
  token     String               @unique @default(cuid())
  courseId  String
  email     String
  role      CourseInstructorRole @default(CO_INSTRUCTOR)
  invitedBy String
  expiresAt DateTime
  usedAt    DateTime?
  usedBy    String?

  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([email])
}

// ─── Course Feedback ──────────────────────────────────────────────────────────

model CourseFeedbackItem {
  id         String    @id @default(cuid())
  courseId   String
  authorId   String
  body       String    @db.Text
  resolvedAt DateTime?
  resolvedBy String?
  createdAt  DateTime  @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  author User   @relation("FeedbackAuthor", fields: [authorId], references: [id])

  @@index([courseId])
  @@index([authorId])
}

// ─── Daily Activity (Streak Tracking) ─────────────────────────────────────────

model DailyActivity {
  id        String   @id @default(cuid())
  userId    String
  date      String // Format: YYYY-MM-DD
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

// ─── Gamification & Achievements System ───────────────────────────────────────

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

model Achievement {
  id          String             @id @default(cuid())
  name        String             @unique
  description String
  icon        String // Name of Lucide icon
  triggerType AchievementTrigger
  threshold   Int
  role        AchievementRole    @default(LEARNER)

  userAchievements UserAchievement[]

  createdAt DateTime @default(now())
}

enum AchievementTrigger {
  LESSON_COUNT
  STUDENT_COUNT
  STREAK_DAYS
  COURSE_COMPLETE
  PUBLISH_COURSE
}

enum AchievementRole {
  LEARNER
  CREATOR
  HYBRID
}

model Quest {
  id          String         @id @default(cuid())
  title       String
  description String
  frequency   QuestFrequency @default(DAILY)
  targetType  QuestTarget
  threshold   Int

  progressItems UserQuestProgress[]

  createdAt DateTime @default(now())
}

enum QuestFrequency {
  DAILY
  WEEKLY
}

enum QuestTarget {
  LESSON_WATCH
  RESOURCE_DOWNLOAD
  REVIEW_REPLY
}

model UserQuestProgress {
  id           String   @id @default(cuid())
  userId       String
  questId      String
  currentValue Int      @default(0)
  isCompleted  Boolean  @default(false)
  resetAt      DateTime // When this quest progress expires (end of day/week)
  updatedAt    DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)

  @@unique([userId, questId, resetAt])
  @@index([userId])
  @@index([questId])
}

model LeaderboardCache {
  id             String   @id @default(cuid())
  userId         String   @unique
  score          Float
  rank           Int
  studentCount   Int      @default(0)
  avgRating      Float    @default(0)
  completionRate Float    @default(0)
  updatedAt      DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Student Rating System ───────────────────────────────────────────────────

model CourseRating {
  id         String   @id @default(cuid())
  courseId   String
  studentId  String
  rating     Int      // 1 to 5 stars
  comment    String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([courseId])
}

// ─── Integrated Certification Exams ──────────────────────────────────────────

model Exam {
  id           String   @id @default(cuid())
  title        String
  duration     Int      // duration in minutes
  passingScore Int      // e.g. 70 for 70%
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  course       Course?  @relation("CourseFinalExam")
  questions    ExamQuestion[]
  attempts     ExamAttempt[]
  scheduleEvents ScheduleEvent[]
}

model ExamQuestion {
  id            String   @id @default(cuid())
  examId        String
  question      String   @db.Text
  type          String   // "mcq" | "coding"
  options       Json?    // String[] options for MCQ
  correctAnswer String   // correct option text or expected result
  codeContext   String?  @db.Text // baseline template for coding challenges
  position      Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers       ExamAnswer[]

  @@index([examId])
}

model ExamAttempt {
  id          String   @id @default(cuid())
  examId      String
  userId      String
  score       Float    @default(0.0)
  passed      Boolean  @default(false)
  startedAt   DateTime @default(now())
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     ExamAnswer[]

  @@index([examId])
  @@index([userId])
}

model ExamAnswer {
  id             String   @id @default(cuid())
  attemptId      String
  questionId     String
  selectedAnswer String   @db.Text
  isCorrect      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  attempt        ExamAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       ExamQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([attemptId])
  @@index([questionId])
}
